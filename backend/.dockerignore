# ============================================================
# 后端 .dockerignore - 排除不必要的文件，优化构建速度
# ============================================================

# 依赖目录（Docker 中会重新安装）
node_modules/

# 编译产物（Docker 中会重新构建）
dist/

# 本地环境配置（不包含在镜像中）
.env
.env.local
.env.*.local

# 版本控制
.git
.gitignore

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 操作系统文件
.DS_Store
Thumbs.db

# 日志和临时文件
logs/
*.log
npm-debug.log*

# 测试
__tests__/
test/
coverage/

# 文档
README.md
